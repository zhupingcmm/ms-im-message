# overlays/prod/.env.example
# 这是 Secret / ConfigMap 里所有环境变量的清单（不含真实值）。
# 真实值通过 k8s-install/scripts/render-secrets.sh 注入到 K8s Secret。
# ConfigMap 里的值已硬编码在 k8s-install/base/configmap-common.yaml。

# ========== 外部中间件（已部署在 8.153.38.116）==========
# 这些地址已写入 ConfigMap im-config，无需手动改：
#   NACOS_ADDR=8.153.38.116:8848
#   DB_HOST=8.153.38.116
#   REDIS_HOST=8.153.38.116
#   KAFKA_SERVERS=8.153.38.116:9092
#   MINIO_ENDPOINT=http://8.153.38.116:9000

# ---------- Secret (im-middleware-secret) ----------
# 外部中间件的所有凭据集中存放在一个 Secret：
DB_PASSWORD=          # 外部 MySQL im_app 业务账号密码（被 im-user / im-message 引用）
MINIO_ACCESS_KEY=     # 外部 MinIO access key（被 im-media / im-message / im-push 引用）
MINIO_SECRET_KEY=     # 外部 MinIO secret key
REDIS_PASSWORD=       # 外部 Redis 密码（生产必填，无密码时留空）

# ---------- Secret (im-jwt-secret) ----------
# 与应用算法相关的密钥，独立管理：
IM_JWT_SECRET=        # openssl rand -hex 32 生成（user/connect/gateway 共享）

# ---------- Ingress 域名 ----------
GATEWAY_HOST=im.example.com
WS_HOST=ws.example.com
